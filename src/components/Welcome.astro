			</label>
			<label class="label-stock">
				Bolsa Caminseta Grande:
				<input type="number" step="0.001" class="input-stock" name="22"/>
			</label>
			<label class="label-stock">
				Arranque 1Kg:
				<input type="number" step="0.001" class="input-stock" name="23"/>
			</label>
			<label class="label-stock">
				Arranque 3Kg:
				<input type="number" step="0.001" class="input-stock" name="24"/>
			</label>
			<label class="label-stock">
				Arranque Milansa:
				<input type="number" step="0.001" class="input-stock" name="25"/>
			</label>
			<label class="label-stock">
				Arranque 10Kg:
				<input type="number" step="0.001" class="input-stock" name="29"/>
			</label>
			<label class="label-stock">
				Cloro:
				<input type="number" step="0.001" class="input-stock" name="26"/>
			</label>
			<label class="label-stock">
				Detergente:
				<input type="number" step="0.001" class="input-stock" name="27"/>
			</label>
			<label class="label-stock">
				Sitronela:
				<input type="number" step="0.001" class="input-stock" name="28"/>
			</label>
			<button class="btn-stock">Submit</button>
		</form>
	
	</div>
</div>


<div
  id="loading"
  class="fixed inset-0 bg-black/50 flex items-center justify-center hidden z-50"
>
  <div class="bg-white p-6 rounded-xl shadow-lg">
    <p class="text-lg font-bold">Guardando datos...</p>
  </div>
</div>

<script>
	const loading = document.getElementById('loading') as HTMLSelectElement ;
	const local = document.getElementById('local') as HTMLSelectElement
	const categoria = document.getElementById('categoria') as HTMLSelectElement
	const formPollo = document.getElementById('pollo') as HTMLFormElement
	const formCerdo = document.getElementById('cerdo') as HTMLFormElement
	const formLimpieza = document.getElementById('limpieza') as HTMLFormElement
	const formAchura = document.getElementById('achura') as HTMLFormElement
	const estado = document.getElementById('estado') as HTMLSelectElement

	categoria?.addEventListener('change',()=>{
		if (categoria.value === 'pollo') {
			formPollo.style.display = 'block'
			formCerdo.style.display = 'none'
			formAchura.style.display = 'none';
			formLimpieza.style.display = 'none';
		
		}
		
		else if(categoria.value === 'cerdo'){
			formPollo.style.display = 'none';
			formCerdo.style.display = 'block';
			formAchura.style.display = 'none';
			formLimpieza.style.display = 'none';
		
		}
		
		else if(categoria.value === 'achura'){
			formPollo.style.display = 'none';
			formCerdo.style.display = 'none';
			formAchura.style.display = 'block';
			formLimpieza.style.display = 'none';
		}
		else{
			formPollo.style.display = 'none';
			formCerdo.style.display = 'none';
			formAchura.style.display = 'none';
			formLimpieza.style.display = 'block';
		}
	})


formPollo.addEventListener('submit', async (e) => {
  e.preventDefault();

  loading.classList.remove('hidden');

  try {

    const formData = new FormData(formPollo);

    for (const [producto_id, cantidad] of formData.entries()) {

      if (!cantidad) continue;

      await fetch('/api/stock', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          local_id: Number(local.value),
          estado_id: Number(estado.value),
          producto_id: Number(producto_id),
          cantidad: Number(cantidad)
        })
      });
    }

    formPollo.reset();

    alert('Stock guardado correctamente');

  } finally {

    loading.classList.add('hidden');

  }
});

