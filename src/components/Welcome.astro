---


export  const prerender = false



---
<div class="min-h-screen bg-slate-100 p-4">
	<div class="bg-white rounded-3xl shadow-lg p-5">

		
		<h1 class="text-3xl font-bold text-center mb-6 text-slate-800">Granja Pico</h1>
		
		<select name="" id="local">
			<option value="2">Granja</option>
			<option value="1">Avicola</option>
		</select>
		
		<select name="categoria" id="categoria">
			<option value="pollo">Pollo</option>
			<option value="cerdo">Cerdo</option>
			<option value="achura">Achura</option>
			<option value="limpieza">limpieza</option>
		</select>

		<select name="estado" id="estado">
			<option value="1">Inicio</option>
			<option value="2">Final</option>
			<option value="3">Ingreso</option>
			<option value="4">Envio</option>
			<option value="5">devolucion</option>
			<option value="6">Produccion</option>
		</select>
		
		
		<!-- formulario Pollo -->
		<form method="POST" id="pollo">
			<label class="label-stock">
